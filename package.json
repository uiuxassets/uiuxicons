{
  "name": "uiuxicons",
  "version": "0.3.2",
  "description": "UI/UX Icons - A clean, consistent icon library for modern interfaces.",
  "author": "UI/UX Icons <hello@uiuxicons.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://uiuxicons.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uiuxassets/uiuxicons.git"
  },
  "bugs": {
    "url": "https://github.com/uiuxassets/uiuxicons/issues"
  },
  "keywords": [
    "icons",
    "svg",
    "ui",
    "ux",
    "design",
    "interface",
    "icon-set",
    "duotone",
    "line-icons",
    "solid-icons"
  ],
  "scripts": {
    "sync": "node scripts/sync.js",
    "build": "node scripts/build.js",
    "check": "tsc --noEmit -p packages/react/tsconfig.json && tsc --noEmit -p packages/vue/tsconfig.json",
    "test": "npm run check && vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@vue/server-renderer": "^3.5.38",
    "archiver": "^8.0.0",
    "fantasticon": "^4.1.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "vitest": "^4.1.8",
    "vue": "^3.5.31"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "@xmldom/xmldom": "^0.9.9",
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.1": true,
    "es5-ext@0.10.64": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "ttf2woff2@8.0.1": true
  }
}
